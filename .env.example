# Blockchain Configuration
# Use a local Ganache instance (UI or CLI) and copy one of the prefunded
# accounts. Each default account comes with plenty of ETH so you can deploy
# without "insufficient funds" errors. You can also transfer ETH to your
# address using the Ganache UI or a simple web3 script.
RPC_URL=http://127.0.0.1:7545
CHAIN_ID=5777
ACCOUNT_ADDRESS=0x... # paste address here
PRIVATE_KEY=0x...   # corresponding private key
